DATABASE_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/dbname?sslmode=require"
BETTER_AUTH_SECRET="replace-with-long-random-secret"
BETTER_AUTH_URL="http://localhost:5173"

MAIL_PROVIDER="gmail"
GMAIL_USER="your@gmail.com"
GOOGLE_APP_PASSWORD="16charapppassword"
SMTP_FROM="your@gmail.com"

# Optional SMTP mode (if MAIL_PROVIDER is not gmail)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"

# Vercel Cron auth token (used as Bearer token for /api/cron/indexnow)
CRON_SECRET="replace-with-long-random-token"
